# ========== CONFIGURAÇÕES DA APLICAÇÃO ==========

# Ambiente
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/terapia

# Configurações do Banco de Dados
DB_HOST=terapia.mysql.dbaas.com.br
DB_DATABASE=terapia
DB_USERNAME=terapia
DB_PASSWORD=Jonathan315@@
DB_CHARSET=utf8mb4

# Configurações de Sessão
SESSION_TIMEOUT=3600
SESSION_NAME=terapia_session

# Configurações de Email (para recuperação de senha)
MAIL_HOST=smtp.seu-email.com
MAIL_PORT=587
MAIL_USERNAME=seu@email.com
MAIL_PASSWORD=sua-senha
MAIL_FROM=noreply@terapia.com
MAIL_ENCRYPTION=tls

# Configurações de Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_PATH=/uploads/

# Chave de Encriptação (gere com: openssl rand -hex 32)
APP_KEY=

# Configurações de mPDF
MPDF_TEMP_DIR=/tmp/mpdf
MPDF_FONT_DIR=/app/fonts
