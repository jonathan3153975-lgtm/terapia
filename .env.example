APP_NAME=Terapia SaaS
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/terapia

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=terapia
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

SESSION_NAME=terapia_session
SESSION_TIMEOUT=7200
UPLOAD_MAX_SIZE=10485760

# ===================================
# Mercado Pago (Assinaturas Paciente)
# ===================================
MP_ACCESS_TOKEN=
MP_API_BASE_URL=https://api.mercadopago.com
MP_CURRENCY_ID=BRL
MP_USE_SANDBOX=true
MP_STATEMENT_DESCRIPTOR=TERAPIA
MP_WEBHOOK_URL=http://localhost/terapia/webhook.php?action=mercado-pago
MP_WEBHOOK_SECRET=

# ===================================
# Email Configuration (SMTP Locaweb)
# ===================================

# Driver de envio: 'smtp' ou 'mail' (fallback)
MAIL_DRIVER=smtp

# Servidor SMTP (Locaweb)
MAIL_HOST=smtplw.com.br

# Porta SMTP (587 para TLS, 465 para SSL)
MAIL_PORT=587

# Tipo de encriptação: 'tls' ou 'ssl'
MAIL_ENCRYPTION=tls

# Email/Username da conta de email Locaweb
# IMPORTANTE: Deve ser um email válido criado na Locaweb
MAIL_USERNAME=seu-email@seu-dominio.com.br

# Senha da conta de email na Locaweb
MAIL_PASSWORD=sua-senha-locaweb

# Email do remetente (pode ser o mesmo de MAIL_USERNAME)
MAIL_FROM_ADDRESS=seu-email@seu-dominio.com.br

# Nome do remetente que aparece nos emails
MAIL_FROM_NAME=Sistema de Terapia
