{
  "name": "terapia/sistema-saas",
  "description": "Sistema SaaS de Gestao para Consultorios de Terapia Sistemica",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "ext-pdo": "*",
    "phpmailer/phpmailer": "^6.8"
  },
  "config": {
    "platform-check": false
  },
  "autoload": {
    "psr-4": {
      "App\\Controllers\\": "app/controllers/",
      "App\\Models\\": "app/models/",
      "Classes\\": "classes/",
      "Config\\": "config/",
      "Helpers\\": "helpers/"
    }
  }
}
